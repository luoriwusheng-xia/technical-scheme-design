# Node environment
NODE_ENV=development
PORT=3000

# OpenAI (required when provider=openai)
OPENAI_API_KEY=sk-xxx

# Anthropic (required when provider=anthropic)
ANTHROPIC_API_KEY=sk-ant-xxx

# Gemini (required when provider=gemini)
GEMINI_API_KEY=xxx

# Fallback / Generic LLM (required when provider=fallback)
FALLBACK_BASE_URL=https://api.deepseek.com/v1
FALLBACK_API_KEY=sk-xxx
